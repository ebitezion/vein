{
  "info": {
    "_postman_id": "e1e6ac6e-c0f1-4ad7-9efe-2ca56d6594d4",
    "name": "Vein Jarakey RBAC MVP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the Vein-based Jarakey RBAC MVP challenge."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "email", "value": "admin@vein.dev" },
    { "key": "password", "value": "VeinPass#2026!" },
    { "key": "estateId", "value": "estate-1" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "1. Healthcheck",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/healthcheck",
          "host": ["{{baseUrl}}"],
          "path": ["healthcheck"]
        }
      },
      "response": []
    },
    {
      "name": "2. Issue Token",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/auth/token",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "auth", "token"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('token', json.auth.token);",
              "pm.test('Token is present', function () { pm.expect(json.auth.token).to.be.a('string').and.not.empty; });"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "3. Open Gate (Should be 200 before downgrade)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "X-Estate-ID", "value": "{{estateId}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/v1/gate/open",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "gate", "open"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "4. Simulate Permission Drift (Downgrade Role)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "X-Estate-ID", "value": "{{estateId}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/v1/challenge/downgrade",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "challenge", "downgrade"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Downgrade status is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "5. Open Gate (Should be 403 after downgrade)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "X-Estate-ID", "value": "{{estateId}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/v1/gate/open",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "gate", "open"]
        },
        "description": "This should now return 403 because role was downgraded in step 4."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 403 after downgrade', function () { pm.response.to.have.status(403); });"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "6. Open Gate without Estate Header (Should be 400)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/v1/gate/open",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "gate", "open"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 400', function () { pm.response.to.have.status(400); });"
            ]
          }
        }
      ],
      "response": []
    }
  ]
}
