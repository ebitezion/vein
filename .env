
# # APP NOMENCLATURE
# APP_NAME = Vein
# APP_VERSION = 0.1
# PORT = 4000
# MY_ENV = development

# DB_DSN=postgres://vein:password@localhost/vein?sslmode=disable


APP_NAME=vein
APP_VERSION=1.0.0
PORT=4000
MY_ENV=development
DB_DSN=
# Optional secret file support for vault/kms mounts:
# DB_DSN_FILE=/var/run/secrets/db_dsn

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_MAX_IDLE_TIME=15m

TOKEN_SECRET=change-me-to-atleast- 32 chars with_mix_Chars
# TOKEN_SECRET_FILE=/var/run/secrets/token_secret
TOKEN_ISSUER=vein
TOKEN_AUDIENCE=vein-clients
TOKEN_TTL=24h

CORS_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10
AUTH_RATE_LIMIT_RPS=1
AUTH_RATE_LIMIT_BURST=3
# TRUSTED_PROXIES accepts CSV of IPs/CIDRs that can set X-Forwarded-For/X-Real-IP:
# TRUSTED_PROXIES=10.0.0.0/8,192.168.0.0/16

# Redis-backed shared infra (optional; leave empty to use in-memory backends)
REDIS_ADDR=
REDIS_PASSWORD=
# REDIS_PASSWORD_FILE=/var/run/secrets/redis_password
REDIS_DB=0
REDIS_QUEUE_KEY=vein:jobs

# OpenTelemetry tracing (optional)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_SAMPLE_RATIO=1.0
